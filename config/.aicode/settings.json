{
  "default_agent": "gemma4",      // Default agent to use when not specified
  "default_provider": "ollama",   // Default provider to use when not specified
  "log_level": "info",
  "providers": {
    "dashscope": {
      "agents": {
        "default": {
          "context_window": 128000,
          "max_tokens": 8192,
          "model": "qwen3.5-plus",
          "temperature": 0.7
        },
        "fast": {
          "context_window": 128000,
          "max_tokens": 1024,
          "model": "qwen-turbo",
          "temperature": 0.1
        }
      },
      "api_key": "sk-sp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "api_type": "qwen",
      "base_url": "https://coding.dashscope.aliyuncs.com/apps/anthropic",
      "timeout": 60
    },
    "ollama": {
      "agents": {
        "default": {
          "context_window": 32768,
          "max_tokens": 8192,
          "model": "qwen3:8b",
          "temperature": 0.7
        },
        "gemma4": {
          "context_window": 128000,
          "max_tokens": 4096,
          "model": "gemma4:e4b",
          "temperature": 0.1
        }
      },
      "api_key": "",
      "api_type": "ollama",
      "base_url": "http://localhost:11434",
      "timeout": 120
    }
  },
  "security": {
    "allow_local_execute": true,
    "permission_level": "auto"
  },
  "show_buddy": true,
  "tools": {
    "enabled": true,
    "timeout": 60
  }
}